# ─── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=

# Base64-encoded Google service-account JSON.
#   On Mac:   base64 -i path/to/key.json | tr -d '\n'
#   On Linux: base64 -w 0 path/to/key.json
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheet ID — the long string between /d/ and /edit in the sheet URL
GOOGLE_SHEET_ID=

# ─── Calendar (one of these) ─────────────────────────────────────────────────

# Single calendar (your Gmail address, or "primary")
GOOGLE_CALENDAR_ID=

# OR: multiple calendars, comma-separated. Takes priority over GOOGLE_CALENDAR_ID.
# Events are read from all listed calendars. Writes go to the FIRST one.
# GOOGLE_CALENDAR_IDS=primary,school@nbss.edu.sg

# Optional: share generated Google Docs/Slides with your Gmail/Workspace email.
# Without this, files are still generated and sent in Telegram, but Drive links
# may be owned by the service account.
GOOGLE_ARTIFACT_SHARE_EMAIL=
GOOGLE_ARTIFACT_SHARE_ROLE=writer
GOOGLE_ARTIFACT_FOLDER_ID=

# Optional override for live MTL classlist Google Sheets.
# Defaults are the 2026 S1-S4 MTL CLASSLIST sheets in the 2026 MTL folder.
# Share these sheets with the service account email so H.I.R.A can read tabs
# containing CG HERWANTO / CG HERWANTO/CG KADIR.
GOOGLE_CLASSLIST_SHEET_IDS=

# Optional Gmail support. Requires Gmail API plus domain-wide delegation for
# the service account if this is a Google Workspace account.
GOOGLE_GMAIL_USER=

# Optional personal Gmail OAuth support. Use these instead of GOOGLE_GMAIL_USER
# for a normal @gmail.com account.
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REFRESH_TOKEN=

# Optional second Gmail inbox for work/MOE email.
# If GOOGLE_WORK_GMAIL_CLIENT_ID/SECRET are blank, H.I.R.A reuses the personal
# OAuth client ID/secret with this separate work refresh token.
GOOGLE_WORK_GMAIL_CLIENT_ID=
GOOGLE_WORK_GMAIL_CLIENT_SECRET=
GOOGLE_WORK_GMAIL_REFRESH_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────────────

# Redis (auto-injected by Railway when you add the Redis addon).
# Without this, conversation history is in-memory only and resets on redeploy.
REDIS_URL=

# Tavily web-search key (free tier: 1000/month). Without this, /search and the
# web_search tool in AI chat are no-ops; the rest of the bot still works.
# Sign up: https://tavily.com
TAVILY_API_KEY=

# Optional voice-note transcription.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Optional PWA/web app protection. If set, the installed H.I.R.A PWA asks for this
# token on first use and sends it as X-Hira-Token.
HIRA_WEB_TOKEN=

# Optional PWA push notifications. Generate VAPID keys with the py-vapid
# `vapid --gen` command. Use `vapid --applicationServerKey` for the public key
# and base64-encode private_key.pem for the private key.
HIRA_WEB_PUSH_PUBLIC_KEY=
HIRA_WEB_PUSH_PRIVATE_KEY=
HIRA_WEB_PUSH_SUBJECT=mailto:you@example.com

# Optional Railway/PWA memory guardrails. Defaults are tuned for small Railway
# containers: one active chat/upload at a time, bounded uploads, and load
# shedding before the container hits the OOM killer.
HIRA_WEB_CHAT_CONCURRENCY=1
HIRA_WEB_UPLOAD_CONCURRENCY=1
HIRA_WEB_HOME_CONCURRENCY=1
HIRA_WEB_MAX_UPLOAD_MB=6
HIRA_WEB_MAX_DOCUMENT_MB=40
HIRA_WEB_MAX_REQUEST_MB=48
HIRA_WEB_MEMORY_GC_RATIO=0.72
HIRA_WEB_MEMORY_REJECT_RATIO=0.84
HIRA_PRAYER_REMINDER_WINDOW_MINUTES=20

# Optional service modes:
# - hira-pwa/web service: HIRA_SERVICE_MODE=pwa
# - PWA notification worker only, no Telegram polling: HIRA_SERVICE_MODE=pwa_worker
HIRA_SERVICE_MODE=bot
