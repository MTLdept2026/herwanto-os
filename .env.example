# ─── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=

# Base64-encoded Google service-account JSON.
#   On Mac:   base64 -i path/to/key.json | tr -d '\n'
#   On Linux: base64 -w 0 path/to/key.json
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheet ID — the long string between /d/ and /edit in the sheet URL
GOOGLE_SHEET_ID=

# ─── Calendar (one of these) ─────────────────────────────────────────────────

# Single calendar (your Gmail address, or "primary")
GOOGLE_CALENDAR_ID=

# OR: multiple calendars, comma-separated. Takes priority over GOOGLE_CALENDAR_ID.
# Events are read from all listed calendars. Writes go to the FIRST one.
# GOOGLE_CALENDAR_IDS=primary,school@nbss.edu.sg

# ─── Optional ────────────────────────────────────────────────────────────────

# Redis (auto-injected by Railway when you add the Redis addon).
# Without this, conversation history is in-memory only and resets on redeploy.
REDIS_URL=

# Tavily web-search key (free tier: 1000/month). Without this, /search and the
# web_search tool in AI chat are no-ops; the rest of the bot still works.
# Sign up: https://tavily.com
TAVILY_API_KEY=
