# ─── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to use the bot.
# Required unless HIRA_TELEGRAM_OPEN_DEV_MODE=1 is set for local development.
HIRA_ALLOWED_USER_IDS=
HIRA_TELEGRAM_OPEN_DEV_MODE=0

# LLM provider for H.I.R.A core chat/tool calls. The runtime is OpenAI-only.
HIRA_LLM_PROVIDER=openai

# OpenAI API key from platform.openai.com.
OPENAI_API_KEY=

# Optional model routing. Leave defaults unless deliberately upgrading the brain.
HIRA_AGENTIC_MODEL=gpt-5.4
HIRA_DEEP_MODEL=gpt-5.5
HIRA_QUICK_MODEL=gpt-5.4-mini
HIRA_ROUTER_MODEL=gpt-5.4-nano
HIRA_STRUCTURED_MODEL=gpt-5.4-mini

# OpenAI full-power mode. Enabled by default:
# stateful Responses API, reasoning controls, prompt caching, action preflight,
# and richer trace includes. Paid native tools are opt-in below.
HIRA_OPENAI_FULL_POWER_MODE=1
HIRA_FAST_CHAT_MODE=1
HIRA_OPENAI_STORE_RESPONSES=1
HIRA_OPENAI_USE_PREVIOUS_RESPONSE_ID=1
HIRA_OPENAI_REASONING_KWARGS=1
HIRA_OPENAI_TRACE_METADATA=1
HIRA_OPENAI_NATIVE_WEB_SEARCH=0
HIRA_OPENAI_NATIVE_CODE_INTERPRETER=0
HIRA_OPENAI_CODE_INTERPRETER_MEMORY_LIMIT=1g
HIRA_OPENAI_INCLUDE_NATIVE_TOOL_RESULTS=1
# Optional: attach OpenAI vector stores for native file search and semantic H.I.R.A memory.
HIRA_OPENAI_FILE_SEARCH_VECTOR_STORE_IDS=
HIRA_OPENAI_MEMORY_VECTOR_STORE_ID=
HIRA_OPENAI_VECTOR_SYNC_ENABLED=0
HIRA_OPENAI_VECTOR_SYNC_MEMORY=1
HIRA_OPENAI_VECTOR_SYNC_UPLOADS=1
HIRA_OPENAI_ACTION_PLANNER=1
HIRA_OPENAI_REALTIME_ENABLED=0
HIRA_OPENAI_USAGE_TRACKING=1
HIRA_OPENAI_USAGE_PERSIST=1
HIRA_OPENAI_USAGE_PERSIST_INTERVAL_SECONDS=60
HIRA_OPENAI_USAGE_SGD_PER_USD=1.35
HIRA_QUICK_ROUTE_MAX_CHARS=220
HIRA_QUICK_REPLY_MAX_TOKENS=160

# News must be fresh. H.I.R.A will not present older headlines as "latest".
HIRA_NEWS_MAX_AGE_HOURS=24

# Base64-encoded Google service-account JSON.
#   On Mac:   base64 -i path/to/key.json | tr -d '\n'
#   On Linux: base64 -w 0 path/to/key.json
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheet ID — the long string between /d/ and /edit in the sheet URL
GOOGLE_SHEET_ID=

# Optional Google user OAuth for Sheets. If configured, H.I.R.A edits Sheets as
# this Google user instead of the service account. Generate with:
#   GOOGLE_REFRESH_ENV=GOOGLE_SHEETS_REFRESH_TOKEN python3 scripts/get_gmail_refresh_token.py
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_SHEETS_REFRESH_TOKEN=

# Optional work Google account OAuth for Sheets/classlists. This takes priority
# over GOOGLE_SHEETS_REFRESH_TOKEN when configured. Generate while signed into
# the work Google account that already has Editor access to the classlist:
#   GOOGLE_REFRESH_ENV=GOOGLE_WORK_SHEETS_REFRESH_TOKEN python3 scripts/get_gmail_refresh_token.py
GOOGLE_WORK_SHEETS_CLIENT_ID=
GOOGLE_WORK_SHEETS_CLIENT_SECRET=
GOOGLE_WORK_SHEETS_REFRESH_TOKEN=

# Optional schedule source. Prefer the full copied Google Sheets link if it
# contains resourcekey=..., because link-shared Drive files can require it.
CCA_SCHEDULE_URL=
CCA_SCHEDULE_SPREADSHEET_ID=
CCA_SCHEDULE_GID=
CCA_SCHEDULE_RESOURCE_KEY=

# ─── Calendar (one of these) ─────────────────────────────────────────────────

# Single calendar (your Gmail address, or "primary")
GOOGLE_CALENDAR_ID=

# OR: multiple calendars, comma-separated. Takes priority over GOOGLE_CALENDAR_ID.
# Events are read from all listed calendars. Writes go to the FIRST one.
# GOOGLE_CALENDAR_IDS=primary,school@example.edu

# Optional: share generated Google Docs/Slides with your Gmail/Workspace email.
# Without this, files are still generated and sent in Telegram, but Drive links
# may be owned by the service account.
GOOGLE_ARTIFACT_SHARE_EMAIL=
GOOGLE_ARTIFACT_SHARE_ROLE=writer
GOOGLE_ARTIFACT_FOLDER_ID=

# Optional override for live classlist Google Sheets.
# Defaults are deployment-specific and should be replaced with your sheet IDs.
# Share these sheets with the service account email so H.I.R.A can read tabs
# containing your configured class/group names.
GOOGLE_CLASSLIST_SHEET_IDS=

# Optional Gmail support. Requires Gmail API plus domain-wide delegation for
# the service account if this is a Google Workspace account.
GOOGLE_GMAIL_USER=

# Optional personal Gmail OAuth support. Use these instead of GOOGLE_GMAIL_USER
# for a normal @gmail.com account.
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REFRESH_TOKEN=

# Optional second personal Gmail inbox.
# If GOOGLE_GMAIL2_CLIENT_ID/SECRET are blank, H.I.R.A reuses the primary
# personal OAuth client ID/secret with this separate refresh token.
GOOGLE_GMAIL2_CLIENT_ID=
GOOGLE_GMAIL2_CLIENT_SECRET=
GOOGLE_GMAIL2_REFRESH_TOKEN=

# Optional experimental Work/MOE Gmail inbox.
# This can fail if the Google Workspace admin blocks third-party Gmail OAuth.
# If GOOGLE_WORK_GMAIL_CLIENT_ID/SECRET are blank, H.I.R.A reuses the primary
# personal OAuth client ID/secret with this separate work refresh token.
GOOGLE_WORK_GMAIL_CLIENT_ID=
GOOGLE_WORK_GMAIL_CLIENT_SECRET=
GOOGLE_WORK_GMAIL_REFRESH_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────────────

# Redis (auto-injected by Railway when you add the Redis addon).
# Without this, conversation history is in-memory only and resets on redeploy.
REDIS_URL=
# Recommended in production once Redis is configured. If enabled, H.I.R.A exits
# instead of silently falling back to process-local memory.
HIRA_REQUIRE_REDIS=0

# Postgres (auto-injected by Railway when you add the Postgres addon).
# When set, assistant memory reads/writes use Postgres as the truth source.
# Set HIRA_POSTGRES_ENABLED=0 for rollback to the legacy Sheets memory path.
DATABASE_URL=
HIRA_POSTGRES_ENABLED=1

# Tavily web-search key (free tier: 1000/month). Without this, /search and the
# web_search tool use no-key fallbacks; the rest of the bot still works.
# Sign up: https://tavily.com
TAVILY_API_KEY=

# Morning digest social-search supplement. Uses Tavily with site:x.com /
# site:twitter.com queries, not an authenticated X API. Requires TAVILY_API_KEY;
# without it the supplement skips silently and the normal Google News digest remains.
# Set to 0 to disable, or add domains like reddit.com,youtube.com if you want
# broader social leads.
HIRA_DIGEST_SOCIAL_SEARCH=1
HIRA_DIGEST_SOCIAL_DOMAINS=x.com,twitter.com
HIRA_DIGEST_SOCIAL_TOPIC_LIMIT=6

# Free no-paid-provider supplements. Adds bounded official/community RSS items
# for selected digest topics (for example Apple Developer, Android Developers,
# OpenAI news, and topic-specific Reddit RSS feeds). This is separate
# from the Tavily/X social supplement above and does not require an API key.
HIRA_DIGEST_FREE_SOURCE_SUPPLEMENTS=1
HIRA_DIGEST_FREE_SOURCE_TOPIC_LIMIT=6

# Optional voice-note transcription.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
HIRA_OPENAI_REALTIME_MODEL=gpt-realtime-2

# Optional PWA/web app protection. If set, the installed H.I.R.A PWA asks for this
# token on first use and sends it as X-Hira-Token.
HIRA_WEB_TOKEN=
HIRA_WEB_AUTH_RATE_LIMIT=8
HIRA_TRUST_PROXY_HEADERS=0

# Optional PWA push notifications. Generate VAPID keys with the py-vapid
# `vapid --gen` command. Use `vapid --applicationServerKey` for the public key
# and base64-encode private_key.pem for the private key.
HIRA_WEB_PUSH_PUBLIC_KEY=
HIRA_WEB_PUSH_PRIVATE_KEY=
HIRA_WEB_PUSH_SUBJECT=mailto:you@example.com

# Optional Railway/PWA guardrails. Defaults are tuned for Railway Hobby:
# modest parallelism, larger education-document uploads, and load shedding
# only when memory pressure is genuinely high.
HIRA_HOME_WORKERS=2
HIRA_WEB_CHAT_CONCURRENCY=2
HIRA_WEB_UPLOAD_CONCURRENCY=2
HIRA_WEB_UPLOAD_QUEUE_WORKERS=2
HIRA_WEB_UPLOAD_QUEUE_MAX=12
HIRA_WEB_HOME_CONCURRENCY=2
HIRA_WEB_MAX_UPLOAD_MB=16
HIRA_WEB_MAX_DOCUMENT_MB=96
HIRA_WEB_MAX_REQUEST_MB=112
HIRA_WEB_MAX_LOCAL_UPLOAD_JOBS=100
HIRA_WEB_MEMORY_GC_RATIO=0.80
HIRA_WEB_MEMORY_REJECT_RATIO=0.92
HIRA_WEB_MEMORY_WATCHDOG_SECONDS=45
HIRA_WEB_CHAT_MAX_TOKENS=3200
HIRA_UVICORN_LIMIT_CONCURRENCY=40
HIRA_MAX_IN_MEMORY_HISTORIES=100
HIRA_CALENDAR_REMINDER_INTERVAL=300
HIRA_CALENDAR_REMINDER_LOOKAHEAD_MINUTES=90
HIRA_CALENDAR_REMINDER_CATCHUP_MINUTES=10
HIRA_DEFAULT_TRAVEL_MINUTES=45
HIRA_TRAVEL_BUFFER_MINUTES=10
HIRA_CALENDAR_TRAVEL_MAX_MINUTES=120
# Optional comma-separated place=minutes estimates, matched by substring.
# HIRA_TRAVEL_TIME_OVERRIDES=HDB Hub=55,NUH=45
# Optional comma-separated terms that make calendar events push reminder-worthy.
# HIRA_CALENDAR_REMINDER_KEYWORDS=appointment,briefing,duty,meeting,submission,training
HIRA_PROACTIVE_INTELLIGENCE_INTERVAL=21600
HIRA_PROACTIVE_INTELLIGENCE_START_HOUR=6
HIRA_PROACTIVE_INTELLIGENCE_END_HOUR=21
HIRA_WORK_GMAIL_MONITOR_ENABLED=1
HIRA_WORK_GMAIL_MONITOR_INTERVAL=1800
HIRA_WORK_GMAIL_MONITOR_QUERY=newer_than:2d
HIRA_WORK_GMAIL_MONITOR_MAX_RESULTS=10
HIRA_WORK_GMAIL_ACTION_SCORE=2
HIRA_WORK_GMAIL_NOTIFY_ON_FIRST_RUN=0
HIRA_WORK_GMAIL_FIRST_RUN_GRACE_MINUTES=60
HIRA_MORNING_BRIEFING_TIME=06:45
HIRA_EVENING_BRIEFING_TIME=21:00
HIRA_DAILY_JOB_GRACE_MINUTES=20
HIRA_MORNING_BRIEFING_CATCHUP_MINUTES=90
HIRA_EVENING_BRIEFING_CATCHUP_MINUTES=90
# Short-lived cache for the Config sheet to avoid Google Sheets read-quota bursts.
HIRA_CONFIG_CACHE_TTL_SECONDS=45
# Short-lived cache for MTL classlist reads to avoid Sheets quota bursts during
# fill + analysis chains.
HIRA_CLASSLIST_CACHE_TTL_SECONDS=120
# Keep proactive briefings/reminders in the separate pwa_worker service.
# Set to 1 only for a single-service fallback deployment.
HIRA_WEB_INLINE_SCHEDULER=0
# Web service safety net: retries queued app notifications that the worker wrote
# to Sheets but failed to deliver through Android/browser Web Push.
HIRA_WEB_PUSH_RECOVERY_ENABLED=1
HIRA_WEB_PUSH_RECOVERY_SECONDS=90
HIRA_WEB_PUSH_RECOVERY_COOLDOWN_SECONDS=300
HIRA_PRAYER_REMINDER_WINDOW_MINUTES=20

# Optional service modes:
# - hira-pwa/web service: HIRA_SERVICE_MODE=pwa
# - PWA notification worker only, no Telegram polling: HIRA_SERVICE_MODE=pwa_worker
HIRA_SERVICE_MODE=bot
